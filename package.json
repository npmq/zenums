{
  "name": "zenums",
  "version": "0.1.5-beta.1",
  "description": "Type-safe enum creation for TypeScript and Zod. Stop duplicating your enums!",
  "keywords": [
    "typescript",
    "zod",
    "enum",
    "string-enum",
    "typescript-enum",
    "zod-enum",
    "literal-union",
    "type-safe",
    "runtime-validation",
    "schema-validation",
    "constants",
    "single-source-of-truth",
    "enum-helper",
    "enum-utility",
    "const-enum-alternative"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/npmq/zenums.git"
  },
  "bugs": {
    "url": "https://github.com/npmq/zenums/issues"
  },
  "homepage": "https://github.com/npmq/zenums#readme",
  "author": {
    "name": "Ant",
    "url": "https://github.com/npmq"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./zod": {
      "types": "./dist/zod.d.ts",
      "import": "./dist/zod.mjs",
      "require": {
        "types": "./dist/zod.d.cts",
        "default": "./dist/zod.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "bun@1.3.13",
  "peerDependencies": {
    "zod": "^3.0.0 || ^4.0.0"
  },
  "peerDependenciesMeta": {
    "zod": {
      "optional": true
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc -p tsconfig.build.json --noEmit",
    "typecheck:test": "tsc -p tsconfig.json --noEmit",
    "typecheck:consumer": "tsc -p tests/consumer/tsconfig.bundler.json --noEmit && tsc -p tests/consumer/tsconfig.nodenext.json --noEmit",
    "lint": "biome lint .",
    "lint:fix": "biome lint . --write",
    "format": "biome format . --write",
    "test:unit": "bun test tests/unit",
    "test:integration": "bun test tests/integration",
    "smoke": "node scripts/smoke.mjs",
    "test": "bun run test:unit",
    "test:all": "bun run test:unit && bun run test:integration && bun run smoke && npm run typecheck:consumer",
    "verify": "npm run lint && npm run typecheck && bun run build && npm run typecheck:test && bun run test:all",
    "prepublishOnly": "npm run verify"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@types/bun": "^1.3.13",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "zod": "^4.3.6"
  }
}
